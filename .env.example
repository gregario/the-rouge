# Rouge env vars reference.
# Copy to .env and fill in what you need. All are optional — Rouge
# ships with sensible defaults for local development.

# ──────────────────────────────────────────────────────────────
# Core paths
# ──────────────────────────────────────────────────────────────

# Where Rouge creates / reads project directories. Default:
# ~/.rouge/projects on global installs, <repo>/projects in source.
# ROUGE_PROJECTS_DIR=~/.rouge/projects

# Absolute path to the rouge CLI executable. The dashboard and
# launcher read this. Default: ~/.rouge/bin/rouge on global installs.
# ROUGE_CLI=/usr/local/bin/rouge

# Root of the Rouge source checkout. Only needed when running from
# an unusual layout.
# ROUGE_ROOT=/path/to/The-Rouge

# Log directory override. Default: <repo>/logs in source checkout
# or ~/.rouge/logs globally. Rouge refuses to fall back to /tmp —
# set this explicitly if HOME isn't available (e.g. running from
# launchd/systemd without a user session).
# ROUGE_LOG_DIR=~/.rouge/logs

# Dashboard home directory. Default: ~/.rouge.
# ROUGE_HOME=~/.rouge

# rouge.config.json override — point at a different config file.
# ROUGE_CONFIG=~/.rouge/rouge.config.json

# Override prompt directory (loop + seeding). Mostly used in tests.
# ROUGE_PROMPTS_DIR=./src/prompts

# Override orchestrator prompt path. Mostly used in tests.
# ROUGE_ORCHESTRATOR_PROMPT=./src/prompts/seeding/00-swarm-orchestrator.md

# ──────────────────────────────────────────────────────────────
# Loop tuning
# ──────────────────────────────────────────────────────────────

# Only run the loop for projects whose slug matches. Used by the
# dashboard's Start button to scope the subprocess to one project.
# ROUGE_PROJECT_FILTER=my-project-slug

# Seconds between loop ticks. Default: 60.
# ROUGE_LOOP_DELAY=60

# Watchdog thresholds for phase execution.
# No progress events for N minutes triggers suspicion.
# ROUGE_PROGRESS_STALE=15
# No log growth for N minutes triggers suspicion.
# ROUGE_LOG_STALE=10
# Hard ceiling on phase duration, minutes.
# ROUGE_HARD_CEILING=60

# Override default Claude model per phase. rouge.config.json.
# model_overrides takes precedence. Mostly used for testing.
# ROUGE_MODEL=opus

# Which LLM provider wizard step picked. Set by the setup wizard.
# ROUGE_LLM_PROVIDER=anthropic

# Secrets storage backend: macos-keychain | linux-secret-service |
# windows-credential-manager | file. Default: platform-native.
# ROUGE_SECRETS_BACKEND=file

# Silence the experimental-feature warning on every launch.
# ROUGE_SUPPRESS_EXPERIMENTAL_WARNING=1

# Behind a trusted proxy? Allow localhost-guard to trust
# x-forwarded-for's first hop. DO NOT set in a default install —
# it opens system/* endpoints to anyone who can craft a header.
# ROUGE_TRUST_PROXY=1

# Path to the browse CLI used by product-walk / QA gate.
# Default: ~/.claude/skills/gstack/browse/dist/browse.
# ROUGE_BROWSE_BIN=/path/to/browse

# ──────────────────────────────────────────────────────────────
# Dashboard
# ──────────────────────────────────────────────────────────────

# Port the Next dashboard listens on. Default: 3000.
# ROUGE_DASHBOARD_PORT=3000
# PORT=3000

# Client-side bridge URL. Usually same-origin; override for split deploys.
# NEXT_PUBLIC_BRIDGE_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# Integrations (populated by `rouge setup`; don't hand-edit these
# unless you know what you're doing — use the keychain instead)
# ──────────────────────────────────────────────────────────────

# GitHub PRs use this as the owner for auto-created repos.
# ROUGE_GITHUB_OWNER=your-github-username

# Slack notification webhook + channel for escalations.
# ROUGE_SLACK_WEBHOOK=https://hooks.slack.com/services/...
# ROUGE_SLACK_CHANNEL=#rouge

# Sentry provisioning (only used when a project declares Sentry).
# SENTRY_ORG=your-org
# SENTRY_TEAM=your-team

# Supabase provisioning token (only used when a project declares Supabase).
# SUPABASE_ACCESS_TOKEN=sbp_...
