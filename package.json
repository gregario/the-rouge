{
  "name": "the-rouge",
  "version": "0.3.1",
  "description": "Autonomous product development system that builds production-quality products through iterative self-evaluation",
  "type": "commonjs",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "gregario",
  "homepage": "https://github.com/gregario/the-rouge",
  "bin": {
    "rouge": "src/launcher/rouge-cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gregario/the-rouge.git"
  },
  "keywords": [
    "ai",
    "autonomous",
    "product-development",
    "claude",
    "karpathy-loop",
    "evaluation",
    "quality"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "ajv": "^8.18.0"
  },
  "scripts": {
    "test": "node tests/secrets.test.js && node tests/cli.test.js && node tests/self-improve.test.js && node tests/auth-mode.test.js && node tests/schema-assignments.test.js && node tests/schema-validator.test.js && node tests/findings-fingerprint.test.js && node tests/integration-manifest.test.js && node --test test/launcher/*.test.js test/prompts/*.test.js test/integration/*.test.js",
    "test:all": "npm test && npm run dashboard:test",
    "dashboard": "cd dashboard && npm run dev",
    "dashboard:install": "cd dashboard && npm install",
    "dashboard:build": "cd dashboard && npm ci --include=dev && npm run build && node ../scripts/stage-standalone.js",
    "dashboard:test": "cd dashboard && npm test",
    "docs:check": "node scripts/check-docs.js && node scripts/generate-cli-reference.js --check",
    "docs:cli": "node scripts/generate-cli-reference.js",
    "prepack": "npm run dashboard:build"
  },
  "files": [
    "src/launcher/",
    "src/prompts/",
    "src/slack/bot.js",
    "src/slack/block-kit.js",
    "src/slack/format.js",
    "src/slack/manifest.yaml",
    "dashboard/dist/",
    "schemas/",
    "library/global/",
    "library/domain/",
    "library/templates/",
    "library/integrations/",
    "library/README.md",
    "rouge.config.json",
    "LICENSE",
    "README.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "VISION.md",
    "docs/slack-setup.md",
    "docs/troubleshooting.md",
    "docs/seeding-example.md"
  ]
}
