{
  "name": "the-rouge",
  "version": "0.3.0",
  "description": "Autonomous product development system that builds production-quality products through iterative self-evaluation",
  "type": "commonjs",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "gregario",
  "homepage": "https://github.com/gregario/the-rouge",
  "bin": {
    "rouge": "src/launcher/rouge-cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gregario/the-rouge.git"
  },
  "keywords": [
    "ai",
    "autonomous",
    "product-development",
    "claude",
    "karpathy-loop",
    "evaluation",
    "quality"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node tests/secrets.test.js && node tests/cli.test.js && node tests/self-improve.test.js && node --test test/launcher/*.test.js test/prompts/*.test.js test/integration/*.test.js",
    "dashboard": "cd dashboard && npm run dev",
    "dashboard:bridge": "cd dashboard && npm run bridge",
    "dashboard:install": "cd dashboard && npm install",
    "dashboard:test": "cd dashboard && npm test"
  },
  "files": [
    "src/launcher/",
    "src/prompts/",
    "src/slack/bot.js",
    "src/slack/block-kit.js",
    "src/slack/format.js",
    "src/slack/manifest.yaml",
    "src/slack/package.json",
    "schemas/",
    "library/global/",
    "library/domain/",
    "library/templates/",
    "library/integrations/",
    "library/README.md",
    "rouge.config.json",
    "LICENSE",
    "README.md",
    "CONTRIBUTING.md",
    "docs/slack-setup.md"
  ]
}
