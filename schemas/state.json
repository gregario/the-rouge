{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rouge Project State",
  "description": "State machine position for a Rouge-managed project. Read by launcher, written by phase prompts.",
  "type": "object",
  "required": ["current_state", "cycle_number", "timestamp"],
  "properties": {
    "current_state": {
      "type": "string",
      "enum": [
        "seeding", "ready",
        "foundation-building", "foundation-evaluating",
        "building", "test-integrity",
        "code-review", "product-walk", "evaluation", "re-walk",
        "qa-fixing", "analyzing", "generating-change-spec",
        "vision-checking", "promoting", "rolling-back",
        "waiting-for-human", "complete"
      ]
    },
    "cycle_number": { "type": "integer", "minimum": 0 },
    "feature_areas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "in-progress", "complete"] }
        }
      }
    },
    "current_feature_area": { "type": ["string", "null"] },
    "qa_fix_attempts": { "type": "integer", "minimum": 0, "default": 0 },
    "po_review_cycles": { "type": "integer", "minimum": 0, "default": 0 },
    "change_specs_pending": { "type": "array", "items": { "type": "string" } },
    "confidence_history": { "type": "array", "items": { "type": "number", "minimum": 0, "maximum": 1 } },
    "paused_from_state": { "type": "string" },
    "foundation": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "not-needed", "in-progress", "complete"] },
        "scope": { "type": "array", "items": { "type": "string" }, "description": "What foundation builds: shared-schema, auth, stripe-integration, app-shell, etc." },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    },
    "detected_profile": {
      "type": "object",
      "properties": {
        "primary": { "type": "string", "enum": ["single-page", "multi-route", "stateful", "api-first", "full-stack"] },
        "secondary": { "type": "array", "items": { "type": "string", "enum": ["single-page", "multi-route", "stateful", "api-first", "full-stack"] }, "maxItems": 1 },
        "detection_method": { "type": "string", "enum": ["explicit", "stack-inferred", "feature-analysis"] },
        "capabilities_activated": { "type": "array", "items": { "type": "string", "enum": ["foundation-cycle", "dependency-ordering", "parallel-building", "integration-pass", "integration-escalation", "foundation-evaluation"] } }
      }
    },
    "budget_cap_usd": {
      "type": "number",
      "minimum": 0,
      "description": "Per-project spend cap in USD. Overrides rouge.config.json's global default. Launcher pauses the loop when cumulative spend exceeds this."
    },
    "authMode": {
      "type": "string",
      "enum": ["subscription", "api", "bedrock", "vertex"],
      "default": "subscription",
      "description": "Which Anthropic auth path the Claude subprocess uses. Set per-spec. Default subscription."
    },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
