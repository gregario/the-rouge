{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rouge Project State (V3)",
  "description": "State machine position for a Rouge-managed project. Read by launcher, written by phase prompts. V3 shape (supersedes V2 state.json schema which enumerated qa-gate / po-reviewing / feature_areas). Validated warn-only — unknown fields are tolerated to keep legacy projects readable.",
  "type": "object",
  "additionalProperties": true,
  "required": ["current_state"],
  "properties": {
    "current_state": {
      "type": "string",
      "enum": [
        "seeding",
        "ready",
        "foundation",
        "foundation-eval",
        "story-building",
        "story-diagnosis",
        "milestone-check",
        "milestone-fix",
        "analyzing",
        "generating-change-spec",
        "vision-check",
        "shipping",
        "final-review",
        "escalation",
        "waiting-for-human",
        "paused",
        "complete"
      ]
    },
    "cycle_number": { "type": "integer", "minimum": 0 },
    "timestamp": { "type": "string" },
    "project": { "type": "string" },
    "name": { "type": "string" },
    "slug": { "type": "string" },
    "archived": { "type": "boolean" },
    "archivedAt": { "type": ["string", "null"] },
    "paused_from_state": { "type": "string" },
    "foundation": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "status": { "type": "string", "enum": ["pending", "not-needed", "in-progress", "complete"] },
        "scope": { "type": "array", "items": { "type": "string" } },
        "completed_at": { "type": "string" }
      }
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string" },
          "stories": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["id"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "status": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "current_milestone": { "type": ["string", "null"] },
    "current_story": { "type": ["string", "null"] },
    "promoted_milestones": { "type": "array", "items": { "type": "string" } },
    "escalations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "tier": { "type": "integer", "minimum": 0 },
          "classification": { "type": "string" },
          "summary": { "type": "string" },
          "reason": { "type": "string" },
          "state": { "type": "string" },
          "story_id": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "created_at": { "type": "string" },
          "resolution": { "type": "string" },
          "resolved_at": { "type": "string" },
          "human_response": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "type": { "type": "string" },
              "text": { "type": "string" },
              "submitted_at": { "type": "string" }
            }
          }
        }
      }
    },
    "stories_executed": { "type": "array" },
    "consecutive_failures": { "type": "integer", "minimum": 0 },
    "costs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "phase_tokens": { "type": "number" },
        "phase_cost_usd": { "type": "number" },
        "cumulative_tokens": { "type": "number" },
        "cumulative_cost_usd": { "type": "number" },
        "phase_cost_source": { "type": "string", "enum": ["parsed", "heuristic"] }
      }
    },
    "budget_cap_usd": { "type": "number", "minimum": 0 },
    "confidence_history": {
      "type": "array",
      "items": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "seedingProgress": { "type": "object", "additionalProperties": true },
    "last_checkpoint_at": { "type": "string" },
    "last_meaningful_progress_at": { "type": ["number", "string"] }
  }
}
