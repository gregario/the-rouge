{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PO Check Template",
  "description": "Parameterized quality check. Instantiated per product during seeding.",
  "type": "object",
  "required": ["id", "dimension", "applies_to", "given", "when", "then", "measurement_method", "default_threshold"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
    "dimension": { "type": "string", "enum": ["feedback", "clarity", "efficiency", "transitions", "delight"] },
    "applies_to": { "type": "string", "enum": ["journey-step", "screen", "interaction", "form", "any"] },
    "given": { "type": "string", "description": "Precondition (may contain {parameter} placeholders)" },
    "when": { "type": "string", "description": "Action or trigger (may contain {parameter} placeholders)" },
    "then": { "type": "string", "description": "Expected outcome (may contain {parameter} placeholders)" },
    "measurement_method": { "type": "string", "enum": ["screenshot-diff", "timing", "dom-analysis", "llm-judgment", "interaction-test", "frame-capture"] },
    "default_threshold": { "description": "Default pass/fail value" },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "default": {}
        }
      }
    }
  }
}
