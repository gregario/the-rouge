{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./src/launcher/rouge-safety-check.sh pre-bash \"$TOOL_INPUT\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "./src/launcher/rouge-safety-check.sh pre-write \"$TOOL_INPUT\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./src/launcher/rouge-safety-check.sh pre-write \"$TOOL_INPUT\""
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "./src/launcher/rouge-safety-check.sh pre-write \"$TOOL_INPUT\""
          }
        ]
      },
      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "./src/launcher/rouge-safety-check.sh pre-write \"$TOOL_INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./src/launcher/rouge-safety-check.sh post-bash \"$TOOL_OUTPUT\""
          }
        ]
      }
    ]
  }
}
