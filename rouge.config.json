{
  "control_plane": "frontend",
  "control_plane_lock": true,
  "safety": {
    "blocked_commands": [],
    "allowed_deploy_targets": [
      "staging",
      "preview"
    ],
    "custom_pre_hooks": []
  },
  "budget_cap_usd": 100,
  "spin_detection": {
    "zero_delta_threshold": 3,
    "time_stall_minutes": 30,
    "dedup_enabled": true
  },
  "model_overrides": {},
  "self_improvement": {
    "enabled": true,
    "allowlist": [
      "src/prompts/loop/*.md",
      "src/prompts/seeding/*.md",
      "docs/design/*.md"
    ],
    "blocklist": [
      "src/launcher/*.js",
      ".claude/settings.json",
      "rouge.config.json",
      "rouge-safety-check.sh"
    ],
    "test_budget_usd": 5
  },
  "self_heal": {
    "enabled": true,
    "zones": ["green"]
  },
  "linked_projects": {
    "max_depth": 3,
    "registry_path": "~/.rouge/registry.json"
  }
}
