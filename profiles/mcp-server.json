{
  "name": "mcp-server",
  "description": "Model Context Protocol server (stdio or HTTP). Consumed by AI agents.",
  "stack_hints": {
    "primary_language": "typescript",
    "targets_browser": false,
    "uses_db": false,
    "typical_stack": "TypeScript + @modelcontextprotocol/sdk"
  },
  "seeding_phases": [
    "brainstorm",
    "taste",
    "spec",
    "infrastructure"
  ],
  "loop_phases": [
    "foundation-building",
    "building",
    "evaluation-orchestrator",
    "analyzing",
    "change-spec-generation",
    "vision-check",
    "ship-promote",
    "document-release",
    "cycle-retrospective"
  ],
  "rules_to_load": ["common", "typescript"],
  "agents_to_enable": [
    "typescript-reviewer",
    "security-reviewer"
  ],
  "mcps_to_enable": [
    "github",
    "context7"
  ],
  "skills_to_load": [
    "iterative-retrieval",
    "tdd-workflow",
    "language-specific-review"
  ],
  "quality_bar": {
    "coverage_min": 85,
    "response_schema_validation": true
  }
}
