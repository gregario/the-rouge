{
  "name": "saas-webapp",
  "description": "Multi-page web SaaS with auth, payments, user dashboard. Public-facing.",
  "stack_hints": {
    "primary_language": "typescript",
    "targets_browser": true,
    "uses_db": true,
    "typical_stack": "Next.js + Supabase + Vercel"
  },
  "seeding_phases": [
    "brainstorm",
    "competition",
    "taste",
    "spec",
    "design",
    "legal",
    "infrastructure"
  ],
  "loop_phases": [
    "foundation-building",
    "building",
    "evaluation-orchestrator",
    "analyzing",
    "change-spec-generation",
    "vision-check",
    "ship-promote",
    "document-release",
    "cycle-retrospective"
  ],
  "rules_to_load": ["common", "typescript", "web"],
  "agents_to_enable": [
    "typescript-reviewer",
    "security-reviewer",
    "silent-failure-hunter"
  ],
  "mcps_to_enable": [
    "supabase",
    "github",
    "playwright",
    "context7",
    "firecrawl",
    "exa",
    "vercel"
  ],
  "skills_to_load": [
    "iterative-retrieval",
    "tdd-workflow",
    "language-specific-review"
  ],
  "quality_bar": {
    "lighthouse_performance_min": 90,
    "lighthouse_accessibility_min": 90,
    "lighthouse_best_practices_min": 90,
    "lighthouse_seo_min": 90,
    "coverage_min": 80,
    "core_web_vitals": { "lcp_ms": 2000, "inp_ms": 200, "cls": 0.1 }
  }
}
