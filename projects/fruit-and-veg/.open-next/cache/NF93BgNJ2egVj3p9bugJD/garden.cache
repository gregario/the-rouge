?\\\",\\\"options\\\":[{\\\"id\\\":\\\"peas-q4-a\\\",\\\"text\\\":\\\"Peas\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"peas-q4-b\\\",\\\"text\\\":\\\"Lentils\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"peas-q4-c\\\",\\\"text\\\":\\\"Carrot\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"peas-q4-d\\\",\\\"text\\\":\\\"Broad Beans\\\",\\\"colour\\\":null,\\\"icon\\\":null}],\\\"correctOptionId\\\":\\\"peas-q4-c\\\",\\\"explanationCorrect\\\":\\\"Yes! Carrot is a root vegetable, not a legume!\\\",\\\"explanationIncorrect\\\":\\\"Hmm, Carrot is the odd one out — it is a root, not a legume!\\\"}],\\\"surpriseFact\\\":\\\"Gregor Mendel discovered the laws of genetics by experimenting on pea plants!\\\",\\\"difficulty\\\":\\\"easy\\\"},{\\\"id\\\":\\\"green-beans\\\",\\\"name\\\":\\\"Green Beans\\\",\\\"image\\\":\\\"/images/catalogue/green-beans.webp\\\",\\\"category\\\":\\\"vegetable\\\",\\\"subcategory\\\":\\\"legume\\\",\\\"colours\\\":[\\\"green\\\"],\\\"growsOn\\\":\\\"vine\\\",\\\"origin\\\":\\\"South America\\\",\\\"season\\\":\\\"summer\\\",\\\"funFacts\\\":[{\\\"text\\\":\\\"I am a long, thin green pod eaten whole!\\\",\\\"highlightWord\\\":\\\"whole\\\",\\\"factType\\\":\\\"surprise\\\"},{\\\"text\\\":\\\"I grow on climbing vines or compact bush plants!\\\",\\\"highlightWord\\\":\\\"climbing\\\",\\\"factType\\\":\\\"growth\\\"},{\\\"text\\\":\\\"I originally came from Central and South America!\\\",\\\"highlightWord\\\":\\\"Central\\\",\\\"factType\\\":\\\"origin\\\"},{\\\"text\\\":\\\"I am a good source of vitamins C and K and folate!\\\",\\\"highlightWord\\\":\\\"folate\\\",\\\"factType\\\":\\\"nutrition\\\"}],\\\"questions\\\":[{\\\"id\\\":\\\"green-beans-q1\\\",\\\"type\\\":\\\"colour-match\\\",\\\"questionText\\\":\\\"What colour am I?\\\",\\\"options\\\":[{\\\"id\\\":\\\"green-beans-q1-a\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#4CAF50\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"green-beans-q1-b\\\",\\\"text\\\":null,\\\