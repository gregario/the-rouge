ue/lime.webp\",\"category\":\"fruit\",\"subcategory\":\"citrus\",\"colours\":[\"green\"],\"growsOn\":\"tree\",\"origin\":\"Southeast Asia\",\"season\":\"all-year\",\"funFacts\":[{\"text\":\"I am small, round, and bright green!\",\"highlightWord\":\"green\",\"factType\":\"colour\"},{\"text\":\"I grow on trees in tropical climates!\",\"highlightWord\":\"tropical\",\"factType\":\"growth\"},{\"text\":\"I am related to lemons and oranges — we are citrus family!\",\"highlightWord\":\"citrus\",\"factType\":\"family\"},{\"text\":\"Sailors used me to prevent scurvy on long voyages!\",\"highlightWord\":\"scurvy\",\"factType\":\"surprise\"}],\"questions\":[{\"id\":\"lime-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour am I?\",\"options\":[{\"id\":\"lime-q1-a\",\"text\":null,\"colour\":\"#FFD700\",\"icon\":null},{\"id\":\"lime-q1-b\",\"text\":null,\"colour\":\"#4CAF50\",\"icon\":null},{\"id\":\"lime-q1-c\",\"text\":null,\"colour\":\"#FF6B35\",\"icon\":null}],\"correctOptionId\":\"lime-q1-b\",\"explanationCorrect\":\"Yes! I am green!\",\"explanationIncorrect\":\"Nearly! I am actually green!\"},{\"id\":\"lime-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"lime-q2-a\",\"text\":\"On a vine\",\"colour\":null,\"icon\":\"🌱\"},{\"id\":\"lime-q2-b\",\"text\":\"On a tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"lime-q2-c\",\"text\":\"Underground\",\"colour\":null,\"icon\":\"🕳️\"}],\"correctOptionId\":\"lime-q2-b\",\"explanationCorrect\":\"Yes! I grow on a tree!\",\"explanationIncorrect\":\"No, I actually grow on a tree!\"},{\"id\":\"lime-q3\",\"type\":\"true-false\",\"questionText\":\"Limes are a type of citrus fruit\",\"options\":[{\"id\":\"lime-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"lime-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"lime-q3-a\",\"explanationCorrect\":\"Correct! I am a citrus fruit!\",\"explanationIncorrect\":\"Actually, I am a citrus fruit!\"},{\"id\":\"lime-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one does NOT belong with the others?\",\"options\":[{\"id\":\"lime-q4-a\",\"text\":\"Lemon\",\"colour\":null,\"icon\":null},{\"id\":\"lime-q4-b\",\"text\":\"Orange\",\"colour\":null,\"icon\":null},{\"id\":\"lime-q4-c\",\"text\":\"Carrot\",\"colour\":null,\"icon\":null},{\"id\":\"lime-q4-d\",\"text\":\"Grapefruit\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"lime-q4-c\",\"explanationCorrect\":\"Yes! Carrot is not a citrus fruit!\",\"explanationIncorrect\":\"Hmm, Carrot is the odd one out!\"}],\"surpriseFact\":\"Key limes are smaller and more fragrant than regular limes!\",\"difficulty\":\"easy\"},{\"id\":\"grapefruit\",\"name\":\"Grapefruit\",\"image\":\"/images/catalogue/grapefruit.webp\",\"category\":\"fruit\",\"subcategory\":\"citrus\",\"colours\":[\"yellow\",\"pink\"],\"growsOn\":\"tree\",\"origin\":\"Caribbean\",\"season\":\"winter\",\"funFacts\":[{\"text\":\"I can be yellow or pink inside — how exciting!\",\"highlightWord\":\"pink\",\"factType\":\"colour\"},{\"text\":\"I grow in clusters on trees, like grapes — that is how I got my name!\",\"highlightWord\":\"clusters\",\"factType\":\"growth\"},{\"text\":\"I was discovered in Barbados in the 1700s!\",\"highlightWord\":\"Barbados\",\"factType\":\"origin\"},{\"text\":\"I am one of the largest citrus fruits in the world!\",\"highlightWord\":\"largest\",\"factType\":\"surprise\"}],\"questions\":[{\"id\":\"grapefruit-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour can I be inside?\",\"options\":[{\"id\":\"grapefruit-q1-a\",\"text\":null,\"colour\":\"#FF69B4\",\"icon\":null},{\"id\":\"grapefruit-q1-b\",\"text\":null,\"colour\":\"#0077B6\",\"icon\":null},{\"id\":\"grapefruit-q1-c\",\"text\":null,\"colour\":\"#8B4513\",\"icon\":null}],\"correctOptionId\":\"grapefruit-q1-a\",\"explanationCorrect\":\"Yes! I can be pink inside!\",\"explanationIncorrect\":\"Nearly! I can be pink or yellow inside!\"},{\"id\":\"grapefruit-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"grapefruit-q2-a\",\"text\":\"On a tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"grapefruit-q2-b\",\"text\":\"On a bush\",\"colour\":null,\"icon\":\"🌿\"},{\"id\":\"grapefruit-q2-c\",\"text\":\"On the ground\",\"colour\":null,\"icon\":\"🌾\"}],\"correctOptionId\":\"grapefruit-q2-a\",\"explanationCorrect\":\"Yes! I grow on a tree!\",\"explanationIncorrect\":\"No, I actually grow on a tree!\"},{\"id\":\"grapefruit-q3\",\"type\":\"true-false\",\"questionText\":\"Grapefruit grows in bunches like grapes\",\"options\":[{\"id\":\"grapefruit-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"grapefruit-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"grapefruit-q3-a\",\"explanationCorrect\":\"Correct! I grow in clusters like grapes!\",\"explanationIncorrect\":\"Actually, I do grow in clusters like grapes!\"},{\"id\":\"grapefruit-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one is NOT a citrus fruit?\",\"options\":[{\"id\":\"grapefruit-q4-a\",\"text\":\"Lemon\",\"colour\":null,\"icon\":null},{\"id\":\"grapefruit-q4-b\",\"text\":\"Mango\",\"colour\":null,\"icon\":null},{\"id\":\"grapefruit-q4-c\",\"text\":\"Lime\",\"colour\":null,\"icon\":null},{\"id\":\"grapefruit-q4-d\",\"text\":\"Orange\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"grapefruit-q4-b\",\"explanationCorrect\":\"Yes! Mango is not a citrus fruit!\",\"explanationIncorrect\":\"Hmm, Mango is the odd one out!\"}],\"surpriseFact\":\"My name comes from growing in grape-like clusters on the tree!\",\"difficulty\":\"easy\"},{\"id\":\"tangerine\",\"name\":\"Tangerine\",\"image\":\"/images/catalogue/tangerine.webp\",\"category\":\"fruit\",\"subcategory\":\"citrus\",\"colours\":[\"orange\"],\"growsOn\":\"tree\",\"origin\":\"China\",\"season\":\"winter\",\"funFacts\":[{\"text\":\"I am a small, sweet orange citrus fruit!\",\"highlightWord\":\"sweet\",\"factType\":\"colour\"},{\"text\":\"