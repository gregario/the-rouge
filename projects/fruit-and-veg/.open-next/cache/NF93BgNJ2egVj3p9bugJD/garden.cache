oes NOT grow on the ground?\",\"options\":[{\"id\":\"melon-q4-a\",\"text\":\"Melon\",\"colour\":null,\"icon\":null},{\"id\":\"melon-q4-b\",\"text\":\"Pumpkin\",\"colour\":null,\"icon\":null},{\"id\":\"melon-q4-c\",\"text\":\"Cucumber\",\"colour\":null,\"icon\":null},{\"id\":\"melon-q4-d\",\"text\":\"Apple\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"melon-q4-d\",\"explanationCorrect\":\"Right! Apples grow on trees, not on the ground!\",\"explanationIncorrect\":\"Apple is the odd one — it grows on a tree!\"}],\"surpriseFact\":\"Watermelons are actually related to cucumbers and pumpkins!\",\"difficulty\":\"easy\"},{\"id\":\"kiwi\",\"name\":\"Kiwi\",\"image\":\"/images/catalogue/kiwi.webp\",\"category\":\"fruit\",\"subcategory\":\"common\",\"colours\":[\"brown\",\"green\"],\"growsOn\":\"vine\",\"origin\":\"China\",\"season\":\"winter\",\"funFacts\":[{\"text\":\"I have fuzzy brown skin but bright green flesh!\",\"highlightWord\":\"green\",\"factType\":\"colour\"},{\"text\":\"I was named after the kiwi bird from New Zealand!\",\"highlightWord\":\"kiwi\",\"factType\":\"origin\"},{\"text\":\"I have more vitamin C than an orange!\",\"highlightWord\":\"vitamin\",\"factType\":\"nutrition\"}],\"questions\":[{\"id\":\"kiwi-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour is my flesh inside?\",\"options\":[{\"id\":\"kiwi-q1-a\",\"text\":null,\"colour\":\"#32CD32\",\"icon\":null},{\"id\":\"kiwi-q1-b\",\"text\":null,\"colour\":\"#FF0000\",\"icon\":null},{\"id\":\"kiwi-q1-c\",\"text\":null,\"colour\":\"#0000FF\",\"icon\":null},{\"id\":\"kiwi-q1-d\",\"text\":null,\"colour\":\"#800080\",\"icon\":null}],\"correctOptionId\":\"kiwi-q1-a\",\"explanationCorrect\":\"Yes! Kiwis are bright green inside!\",\"explanationIncorrect\":\"Kiwis have bright green flesh inside!\"},{\"id\":\"kiwi-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"kiwi-q2-a\",\"text\":\"On a vine\",\"colour\":null,\"icon\":\"🌱\"},{\"id\":\"kiwi-q2-b\",\"text\":\"On a tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"kiwi-q2-c\",\"text\":\"Underground\",\"colour\":null,\"icon\":\"🕳️\"},{\"id\":\"kiwi-q2-d\",\"text\":\"On a bush\",\"colour\":null,\"icon\":\"🌿\"}],\"correctOptionId\":\"kiwi-q2-a\",\"explanationCorrect\":\"Right! Kiwis grow on vines!\",\"explanationIncorrect\":\"Kiwis actually grow on vines!\"},{\"id\":\"kiwi-q3\",\"type\":\"true-false\",\"questionText\":\"I was named after a bird. True or false?\",\"options\":[{\"id\":\"kiwi-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"kiwi-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"kiwi-q3-a\",\"explanationCorrect\":\"Yes! Named after the kiwi bird from New Zealand!\",\"explanationIncorrect\":\"Actually, kiwi fruit was named after the kiwi bird!\"},{\"id\":\"kiwi-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one is NOT green inside?\",\"options\":[{\"id\":\"kiwi-q4-a\",\"text\":\"Kiwi\",\"colour\":null,\"icon\":null},{\"id\":\"kiwi-q4-b\",\"text\":\"Avocado\",\"colour\":null,\"icon\":null},{\"id\":\"kiwi-q4-c\",\"text\":\"Cucumber\",\"colour\":null,\"icon\":null},{\"id\":\"kiwi-q4-d\",\"text\":\"Mango\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"kiwi-q4-d\",\"explanationCorrect\":\"Right! Mango is orange inside, not green!\",\"explanationIncorrect\":\"Mango is the odd one — it is orange inside!\"}],\"surpriseFact\":\"Kiwi skin is actually edible and packed with nutrients!\",\"difficulty\":\"easy\"},{\"id\":\"mango\",\"name\":\"Mango\",\"image\":\"/images/catalogue/mango.webp\",\"category\":\"fruit\",\"subcategory\":\"tropical\",\"colours\":[\"orange\",\"yellow\",\"green\",\"red\"],\"growsOn\":\"tree\",\"origin\":\"South Asia\",\"season\":\"summer\",\"funFacts\":[{\"text\":\"I am the king of fruits in many countries!\",\"highlightWord\":\"king\",\"factType\":\"surprise\"},{\"text\":\"My flesh is sweet, juicy and bright orange inside!\",\"highlightWord\":\"orange\",\"factType\":\"colour\"},{\"text\":\"I grow on tall leafy trees in warm sunshine!\",\"highlightWord\":\"trees\",\"factType\":\"growth\"},{\"text\":\"Over 1,000 different varieties of me exist worldwide!\",\"highlightWord\":\"varieties\",\"factType\":\"surprise\"}],\"questions\":[{\"id\":\"mango-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour am I inside?\",\"options\":[{\"id\":\"mango-q1-a\",\"text\":null,\"colour\":\"#FFA500\",\"icon\":null},{\"id\":\"mango-q1-b\",\"text\":null,\"colour\":\"#0000FF\",\"icon\":null},{\"id\":\"mango-q1-c\",\"text\":null,\"colour\":\"#FFFFFF\",\"icon\":null},{\"id\":\"mango-q1-d\",\"text\":null,\"colour\":\"#800080\",\"icon\":null}],\"correctOptionId\":\"mango-q1-a\",\"explanationCorrect\":\"Yes! I am a gorgeous orange colour inside!\",\"explanationIncorrect\":\"Not quite! I am orange and juicy inside.\"},{\"id\":\"mango-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"mango-q2-a\",\"text\":\"Tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"mango-q2-b\",\"text\":\"Bush\",\"colour\":null,\"icon\":\"🌿\"},{\"id\":\"mango-q2-c\",\"text\":\"Vine\",\"colour\":null,\"icon\":\"🌱\"},{\"id\":\"mango-q2-d\",\"text\":\"Ground\",\"colour\":null,\"icon\":\"🌍\"}],\"correctOptionId\":\"mango-q2-a\",\"explanationCorrect\":\"That's right! I grow on big, tall trees!\",\"explanationIncorrect\":\"Nope! I hang from tall trees in warm countries.\"},{\"id\":\"mango-q3\",\"type\":\"true-false\",\"questionText\":\"Mangoes are related to cashew nuts. True or false?\",\"options\":[{\"id\":\"mango-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"mango-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"mango-q3-a\",\"explanationCorrect\":\"True! Mangoes, cashews and pistachios are all in the same family!\",\"explanationIncorrect\":\"Actually true! Mangoes are cousins of cashews and pistachios.\"},{\"id\":\"mango-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one does NOT belong with the others?\",\"options\":[{\"id\":\"mango-q4-a\",\"text\":\"Mango\",\"colour\":null,\"icon\":null},{\"id\":\"mango-q4-b\",\"text\":\"Pineapple\",\"colour\":null,\"icon\":null},{\"id\":\"mango-q4-c\",\"text\":\"Papaya\",\"colour\":null,\"icon\":null},{\"id\":\"mango-q4-d\",\"text\":\"Broccoli\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"mango-q4-d\",\"explanationCorrect\":\"Correct! Broccoli is a vegetable — the others are all tropical fruits!\",\"explanationIncorrect\":\"Broccoli is the odd one out — it's a vegetable, not a tropical fruit!\"}],\"surpriseFact\":\"Mangoes are related to cashews and pistachios — they're all in the same plant family!\",\"difficulty\":\"easy\"},{\"id\":\"pineapple\",\"name\":\"Pineapple\",\"image\":\"/images/catalogue/pineapple.webp\",\"category\":\"fruit\",\"subcategory\":\"tropical\",\"colours\":[\"yellow\",\"green\",\"brown\"],\"growsOn\":\"ground\",\"origin\":\"South America\",\"season\":\"summer\",\"funFacts\":[{\"text\":\"I grow from the ground on a low leafy plant!\",\"highlightWord\":\"ground\",\"factType\":\"growth\"},{\"text\":\"My spiky crown can be planted to grow a new me!\",\"highlightWord\":\"crown\",\"factType\":\"surprise\"},{\"text\":\"I am yellow and sweet with a tangy tropical taste!\",\"highlightWord\":\"sweet\",\"factType\":\"surprise\"},{\"text\":\"It takes almost two years for me to fully grow!\",\"highlightWord\":\"years\",\"factType\":\"surprise\"}],\"questions\":[{\"id\":\"pineapple-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour am I inside?\",\"options\":[{\"id\":\"pineapple-q1-a\",\"text\":null,\"colour\":\"#FFD700\",\"icon\":null},{\"id\":\"pineapple-q1-b\",\"text\":null,\"colour\":\"#FF0000\",\"icon\":null},{\"id\":\"pineapple-q1-c\",\"text\":null,\"colour\":\"#800080\",\"icon\":null},{\"id\":\"pineapple-q1-d\",\"text\":null,\"colour\":\"#228B22\",\"icon\":null}],\"correctOptionId\":\"pineapple-q1-a\",\"explanationCorrect\":\"Yes! I am bright yellow and juicy inside!\",\"explanationIncorrect\":\"Not quite! I am golden yellow inside.\"},{\"id\":\"pineapple-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"pineapple-q2-a\",\"text\":\"Tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"pineapple-q2-b\",\"text\":\"Bush\",\"colour\":null,\"icon\":\"🌿\"},{\"id\":\"pineapple-q2-c\",\"text\":\"Vine\",\"colour\":null,\"icon\":\"🌱\"},{\"id\":\"pineapple-q2-d\",\"text\":\"Ground\",\"colour\":null,\"icon\":\"🌍\"}],\"correctOptionId\":\"pineapple-q2-d\",\"explanationCorrect\":\"Yes! I grow close to the ground on a low plant!\",\"explanationIncorrect\":\"Surprise! I actually grow on a low plant close to the ground.\"},{\"id\":\"pineapple-q3\",\"type\":\"true-false\",\"questionText\":\"It takes two years for a pineapple to grow. True or false?\",\"options\":[{\"id\":\"pineapple-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"pineapple-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"pineapple-q3-a\",\"explanationCorrect\":\"True! A pineapple plant produces one fruit every two years!\",\"explanationIncorrect\":\"Actually true! It takes about two years to grow one pineapple.\"},{\"id\":\"pineapple-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one does NOT belong with the others?\",\"options\":[{\"id\":\"pineapple-q4-a\",\"text\":\"Pineapple\",\"colour\":null,\"icon\":null},{\"id\":\"pineapple-q4-b\",\"text\":\"Mango\",\"colour\":null,\"icon\":null},{\"id\":\"pineapple-q4-c\",\"text\":\"Carrot\",\"colour\":null,\"icon\":null},{\"id\":\"pineapple-q4-d\",\"text\":\"Coconut\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"pineapple-q4-c\",\"explanationCorrect\":\"Correct! Carrot is a vegetable — the rest are tropical fruits!\",\"explanationIncorrect\":\"Carrot is the odd one out — it's a vegetable, not a tropical fruit!\"}],\"surpriseFact\":\"Each pineapple takes up to two years to grow — and a plant only produces one pineapple at a time!\",\"difficulty\":\"easy\"},{\"id\":\"coconut\",\"name\":\"Coconut\",\"image\":\"/images/catalogue/coconut.webp\",\"category\":\"fruit\",\"subcategory\":\"tropical\",\"colours\":[\"brown\",\"white\",\"green\"],\"growsOn\":\"tree\",\"origin\":\"Southeast Asia\",\"season\":\"all-year\",\"funFacts\":[{\"text\":\"I have a hard brown shell protecting my white flesh!\",\"highlightWord\":\"shell\",\"factType\":\"surprise\"},{\"text\":\"I grow high up on tall palm trees near the ocean!\",\"highlightWord\":\"palm\",\"factType\":\"growth\"},{\"text\":\"My water inside is a delicious and refreshing drink!\",\"highlightWord\":\"water\",\"factType\":\"surprise\"},{\"text\":\"I am a fruit, a nut and a seed all at once!\",\"highlightWord\":\"nut\",\"factType\":\"family\"}],\"questions\":[{\"id\":\"coconut-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour am I on the outside?\",\"options\":[{\"id\":\"coconut-q1-a\",\"text\":null,\"colour\":\"#8B4513\",\"icon\":null},{\"id\":\"coconut-q1-b\",\"text\":null,\"colour\":\"#FFD700\",\"icon\":null},{\"id\":\"coconut-q1-c\",\"text\":null,\"colour\":\"#FF69B4\",\"icon\":null},{\"id\":\"coconut-q1-d\",\"text\":null,\"colour\":\"#DC143C\",\"icon\":null}],\"correctOptionId\":\"coconut-q1-a\",\"explanationCorrect\":\"Yes! My hard outer shell is a dark brown colour!\",\"explanationIncorrect\":\"Not quite! My hard shell is brown on the outside.\"},{\"id\":\"coconut-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"coconut-q2-a\",\"text\":\"Tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"coconut-q2-b\",\"text\":\"Bush\",\"colour\":null,\"icon\":\"🌿\"},{\"id\":\"coconut-q2-c\",\"text\":\"Vine\",\"colour\":null,\"icon\":\"🌱\"},{\"id\":\"coconut-q2-d\",\"text\":\"Ground\",\"colour\":null,\"icon\":\"🌍\"}],\"correctOptionId\":\"coconut-q2-a\",\"explanationCorrect\":\"Yes! I grow way up high on tall palm trees!\",\"explanationIncorrect\":\"Nope! I grow on tall palm trees near tropical beaches.\"},{\"id\":\"coconut-q3\",\"type\":\"true-false\",\"questionText\":\"A coconut is a fruit, nut and seed. True or false?\",\"options\":[{\"id\":\"coconut-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"coconut-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"coconut-q3-a\",\"explanationCorrect\":\"True! Scientists class the coconut as all three!\",\"explanationIncorrect\":\"Actually true! A coconut can be called a fruit, a nut, or a seed.\"},{\"id\":\"coconut-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one does NOT belong with the others?\",\"options\":[{\"id\":\"coconut-q4-a\",\"text\":\"Coconut\",\"colour\":null,\"icon\":null},{\"id\":\"coconut-q4-b\",\"text\":\"Mango\",\"colour\":null,\"icon\":null},{\"id\":\"coconut-q4-c\",\"text\":\"Pineapple\",\"colour\":null,\"icon\":null},{\"id\":\"coconut-q4-d\",\"text\":\"Potato\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"coconut-q4-d\",\"explanationCorrect\":\"Correct! Potato is a vegetable — the others are all tropical fruits!\",\"explanationIncorrect\":\"Potato is the odd one out — it's a vegetable, not a tropical fruit!\"}],\"surpriseFact\":\"Coconut water was used as emergency IV fluid during World War II!\",\"difficulty\":\"easy\"},{\"id\":\"papaya\",\"name\":\"Papaya\",\"image\":\"/images/catalogue/papaya.webp\",\"category\":\"fruit\",\"subcategory\":\"tropical\",\"colours\":[\"orange\",\"yellow\",\"green\"],\"growsOn\":\"tree\",\"origin\":\"Central America\",\"season\":\"summer\",\"funFacts\":[{\"text\":\"I am orange inside with lots of black seeds!\",\"highlightWord\":\"seeds\",\"factType\":\"surprise\"},{\"text\":\"I contain a special ingredient that helps digestion!\",\"highlightWord\":\"digestion\",\"factType\":\"nutrition\"},{\"text\":\"Columbus called me the fruit of the angels!\",\"highlightWord\":\"angels\",\"factType\":\"origin\"},{\"text\":\"I can grow up to half a metre long!\",\"highlightWord\":\"metre\",\"factType\":\"surprise\"}],\"questions\":[{\"id\":\"papaya-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour am I inside?\",\"options\":[{\"id\":\"papaya-q1-a\",\"text\":null,\"colour\":\"#FF8C00\",\"icon\":null},{\"id\":\"papaya-q1-b\",\"text\":null,\"colour\":\"#0000CD\",\"icon\":null},{\"id\":\"papaya-q1-c\",\"text\":null,\"colour\":\"#FFFFFF\",\"icon\":null},{\"id\":\"papaya-q1-d\",\"text\":null,\"colour\":\"#8B008B\",\"icon\":null}],\"correctOptionId\":\"papaya-q1-a\",\"explanationCorrect\":\"Yes! I am a beautiful deep orange colour inside!\",\"explanationIncorrect\":\"Not quite! I am deep orange inside, with black seeds.\"},{\"id\":\"papaya-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"papaya-q2-a\",\"text\":\"Tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"papaya-q2-b\",\"text\":\"Bush\",\"colour\":null,\"icon\":\"🌿\"},{\"id\":\"papaya-q2-c\",\"text\":\"Vine\",\"colour\":null,\"icon\":\"🌱\"},{\"id\":\"papaya-q2-d\",\"text\":\"Ground\",\"colour\":null,\"icon\":\"🌍\"}],\"correctOptionId\":\"papaya-q2-a\",\"explanationCorrect\":\"Yes! I grow on tall, slender tropical trees!\",\"explanationIncorrect\":\"Nope! I grow on tall slender trees in tropical climates.\"},{\"id\":\"papaya-q3\",\"type\":\"true-false\",\"questionText\":\"Papaya seeds can be eaten. True or false?\",\"options\":[{\"id\":\"papaya-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"papaya-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"papaya-q3-a\",\"explanationCorrect\":\"True! Papaya seeds are edible and taste a bit peppery!\",\"explanationIncorrect\":\"Actually true! Papaya seeds can be eaten — they taste like pepper!\"},{\"id\":\"papaya-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one does NOT belong with the others?\",\"options\":[{\"id\":\"papaya-q4-a\",\"text\":\"Papaya\",\"colour\":null,\"icon\":null},{\"id\":\"papaya-q4-b\",\"text\":\"Mango\",\"colour\":null,\"icon\":null},{\"id\":\"papaya-q4-c\",\"text\":\"Pineapple\",\"colour\":null,\"icon\":null},{\"id\":\"papaya-q4-d\",\"text\":\"Lettuce\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"papaya-q4-d\",\"explanationCorrect\":\"Correct! Lettuce is a vegetable — the others are tropical fruits!\",\"explanationIncorrect\":\"Lettuce is the odd one out — it's a vegetable, not a tropical fruit!\"}],\"surpriseFact\":\"Papaya contains an enzyme called papain used to tenderise meat!\",\"difficulty\":\"medium\"},{\"id\":\"passion-fruit\",\"name\":\"Passion Fruit\",\"image\":\"/images/catalogue/passion-fruit.webp\",\"category\":\"fruit\",\"subcategory\":\"tropical\",\"colours\":[\"purple\",\"yellow\",\"orange\"],\"growsOn\":\"vine\",\"origin\":\"South America\",\"season\":\"summer\",\"funFacts\":[{\"text\":\"I grow on a climbing vine with beautiful flowers!\",\"highlightWord\":\"flowers\",\"factType\":\"growth\"},{\"text\":\"Inside I am full of juicy seeds in golden pulp!\",\"highlightWord\":\"seeds\",\"factType\":\"surprise\"},{\"text\":\"My wrinkly skin means I am perfectly ripe!\",\"highlightWord\":\"wrinkly\",\"factType\":\"surprise\"},{\"text\":\"I get my name from the beautiful passion flower!\",\"highlightWord\":\"passion\",\"factType\":\"family\"}],\"questions\":[{\"id\":\"passion-fruit-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour is my skin when ripe?\",\"options\":[{\"id\":\"passion-fruit-q1-a\",\"text\":null,\"colour\":\"#4B0082\",\"icon\":null},{\"id\":\"passion-fruit-q1-b\",\"text\":null,\"colour\":\"#FF0000\",\"icon\":null},{\"id\":\"passion-fruit-q1-c\",\"text\":null,\"colour\":\"#32CD32\",\"icon\":null},{\"id\":\"passion-fruit-q1-d\",\"text\":null,\"colour\":\"#FFC0CB\",\"icon\":null}],\"correctOptionId\":\"passion-fruit-q1-a\",\"explanationCorrect\":\"Yes! My skin turns a deep purple when I am ripe!\",\"explanationIncorrect\":\"Not quite! I turn deep purple when I am ready to eat.\"},{\"id\":\"passion-fruit-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"passion-fruit-q2-a\",\"text\":\"Tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"passion-fruit-q2-b\",\"text\":\"Bush\",\"colour\":null,\"icon\":\"🌿\"},{\"id\":\"passion-fruit-q2-c\",\"text\":\"Vine\",\"colour\":null,\"icon\":\"🌱\"},{\"id\":\"passion-fruit-q2-d\",\"text\":\"Ground\",\"colour\":null,\"icon\":\"🌍\"}],\"correctOptionId\":\"passion-fruit-q2-c\",\"explanationCorrect\":\"Yes! I climb and grow on beautiful flowering vines!\",\"explanationIncorrect\":\"Nope! I grow on climbing vines with stunning tropical flowers.\"},{\"id\":\"passion-fruit-q3\",\"type\":\"true-false\",\"questionText\":\"I am named after the passion flower. True or false?\",\"options\":[{\"id\":\"passion-fruit-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"passion-fruit-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"passion-fruit-q3-a\",\"explanationCorrect\":\"True! I grow from the stunning passion flower vine!\",\"explanationIncorrect\":\"Actually true! I grow on the passion flower vine — that's how I got my name!\"},{\"id\":\"passion-fruit-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one does NOT belong with the others?\",\"options\":[{\"id\":\"passion-fruit-q4-a\",\"text\":\"Passion Fruit\",\"colour\":null,\"icon\":null},{\"id\":\"passion-fruit-q4-b\",\"text\":\"Mango\",\"colour\":null,\"icon\":null},{\"id\":\"passion-fruit-q4-c\",\"text\":\"Spinach\",\"colour\":null,\"icon\":null},{\"id\":\"passion-fruit-q4-d\",\"text\":\"Papaya\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"passion-fruit-q4-c\",\"explanationCorrect\":\"Correct! Spinach is a leafy vegetable — the others are tropical fruits!\",\"explanationIncorrect\":\"Spinach is the odd one out — it's a leafy green, not a tropical fruit!\"}],\"surpriseFact\":\"The passion flower vine was named by Spanish missionaries!\",\"difficulty\":\"medium\"},{\"id\":\"guava\",\"name\":\"Guava\",\"image\":\"/images/catalogue/guava.webp\",\"category\":\"fruit\",\"subcategory\":\"tropical\",\"colours\":[\"green\",\"yellow\",\"pink\",\"white\"],\"growsOn\":\"tree\",\"origin\":\"Central America\",\"season\":\"autumn\",\"funFacts\":[{\"text\":\"I have way more vitamin C than an orange does!\",\"highlightWord\":\"vitamin\",\"factType\":\"nutrition\"},{\"text\":\"My flesh can be white or bright pink inside!\",\"highlightWord\":\"pink\",\"factType\":\"colour\"},{\"text\":\"I smell amazing — sweet and floral all at once!\",\"highlightWord\":\"smell\",\"factType\":\"surprise\"},{\"text\":\"Even my leaves are used to make healthy tea!\",\"highlightWord\":\"leaves\",\"factType\":\"nutrition\"}],\"questions\":[{\"id\":\"guava-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour can I be inside?\",\"options\":[{\"id\":\"guava-q1-a\",\"text\":null,\"colour\":\"#FF69B4\",\"icon\":null},{\"id\":\"guava-q1-b\",\"text\":null,\"colour\":\"#000080\",\"icon\":null},{\"id\":\"guava-q1-c\",\"text\":null,\"colour\":\"#8B4513\",\"icon\":null},{\"id\":\"guava-q1-d\",\"text\":null,\"colour\":\"#2F4F4F\",\"icon\":null}],\"correctOptionId\":\"guava-q1-a\",\"explanationCorrect\":\"Yes! I can be a lovely pink colour inside!\",\"explanationIncorrect\":\"Not quite! I can be pink or white inside.\"},{\"id\":\"guava-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"guava-q2-a\",\"text\":\"Tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"guava-q2-b\",\"text\":\"Bush\",\"colour\":null,\"icon\":\"🌿\"},{\"id\":\"guava-q2-c\",\"text\":\"Vine\",\"colour\":null,\"icon\":\"🌱\"},{\"id\":\"guava-q2-d\",\"text\":\"Ground\",\"colour\":null,\"icon\":\"🌍\"}],\"correctOptionId\":\"guava-q2-a\",\"explanationCorrect\":\"Yes! I grow on small tropical trees!\",\"explanationIncorrect\":\"Nope! I grow on small trees in tropical regions.\"},{\"id\":\"guava-q3\",\"type\":\"true-false\",\"questionText\":\"Guava has more vitamin C than an orange. True or false?\",\"options\":[{\"id\":\"guava-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"guava-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"guava-q3-a\",\"explanationCorrect\":\"True! Guava has four times more vitamin C than an orange!\",\"explanationIncorrect\":\"Actually true! Guava has loads more vitamin C than an orange!\"},{\"id\":\"guava-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one does NOT belong with the others?\",\"options\":[{\"id\":\"guava-q4-a\",\"text\":\"Guava\",\"colour\":null,\"icon\":null},{\"id\":\"guava-q4-b\",\"text\":\"Mango\",\"colour\":null,\"icon\":null},{\"id\":\"guava-q4-c\",\"text\":\"Coconut\",\"colour\":null,\"icon\":null},{\"id\":\"guava-q4-d\",\"text\":\"Onion\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"guava-q4-d\",\"explanationCorrect\":\"Correct! Onion is a vegetable — the others are all tropical fruits!\",\"explanationIncorrect\":\"Onion is the odd one out — it's a vegetable, not a tropical fruit!\"}],\"surpriseFact\":\"One guava gives you all the vitamin C you need for a whole day!\",\"difficulty\":\"medium\"},{\"id\":\"lychee\",\"name\":\"Lychee\",\"image\":\"/images/catalogue/lychee.webp\",\"category\":\"fruit\",\"subcategory\":\"tropical\",\"colours\":[\"red\",\"pink\",\"white\"],\"growsOn\":\"tree\",\"origin\":\"China\",\"season\":\"summer\",\"funFacts\":[{\"text\":\"I have a rough red skin but soft white flesh!\",\"highlightWord\":\"white\",\"factType\":\"colour\"},{\"text\":\"I taste like a mix of rose, pear and grape!\",\"highlightWord\":\"rose\",\"factType\":\"surprise\"},{\"text\":\"I have been grown in China for over 2,000 years!\",\"highlightWord\":\"China\",\"factType\":\"origin\"},{\"text\":\"I hide a shiny dark brown seed in my centre!\",\"highlightWord\":\"seed\",\"factType\":\"surprise\"}],\"questions\":[{\"id\":\"lychee-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour is my skin?\",\"options\":[{\"id\":\"lychee-q1-a\",\"text\":null,\"colour\":\"#DC143C\",\"icon\":null},{\"id\":\"lychee-q1-b\",\"text\":null,\"colour\":\"#FFD700\",\"icon\":null},{\"id\":\"lychee-q1-c\",\"text\":null,\"colour\":\"#1E90FF\",\"icon\":null},{\"id\":\"lychee-q1-d\",\"text\":null,\"colour\":\"#228B22\",\"icon\":null}],\"correctOptionId\":\"lychee-q1-a\",\"explanationCorrect\":\"Yes! My bumpy outer skin is a bright red colour!\",\"explanationIncorrect\":\"Not quite! My bumpy skin is red on the outside.\"},{\"id\":\"lychee-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"lychee-q2-a\",\"text\":\"Tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"lychee-q2-b\",\"text\":\"Bush\",\"colour\":null,\"icon\":\"🌿\"},{\"id\":\"lychee-q2-c\",\"text\":\"Vine\",\"colour\":null,\"icon\":\"🌱\"},{\"id\":\"lychee-q2-d\",\"text\":\"Ground\",\"colour\":null,\"icon\":\"🌍\"}],\"correctOptionId\":\"lychee-q2-a\",\"explanationCorrect\":\"Yes! I grow in big bunches on leafy trees!\",\"explanationIncorrect\":\"Nope! I grow in clusters on trees in warm parts of Asia.\"},{\"id\":\"lychee-q3\",\"type\":\"true-false\",\"questionText\":\"Lychees originally come from China. True or false?\",\"options\":[{\"id\":\"lychee-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"lychee-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"lychee-q3-a\",\"explanationCorrect\":\"True! Lychees have been grown in China for over 2,000 years!\",\"explanationIncorrect\":\"Actually true! Lychees originally come from China.\"},{\"id\":\"lychee-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one does NOT belong with the others?\",\"options\":[{\"id\":\"lychee-q4-a\",\"text\":\"Lychee\",\"colour\":null,\"icon\":null},{\"id\":\"lychee-q4-b\",\"text\":\"Mango\",\"colour\":null,\"icon\":null},{\"id\":\"lychee-q4-c\",\"text\":\"Guava\",\"colour\":null,\"icon\":null},{\"id\":\"lychee-q4-d\",\"text\":\"Mushroom\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"lychee-q4-d\",\"explanationCorrect\":\"Correct! Mushroom is a fungus — the others are tropical fruits!\",\"explanationIncorrect\":\"Mushroom is the odd one out — it's not a tropical fruit!\"}],\"surpriseFact\":\"Lychees were so loved by Chinese emperors that horses rushed them to the palace!\",\"difficulty\":\"medium\"},{\"id\":\"starfruit\",\"name\":\"Starfruit\",\"image\":\"/images/catalogue/starfruit.webp\",\"category\":\"fruit\",\"subcategory\":\"tropical\",\"colours\":[\"yellow\",\"green\"],\"growsOn\":\"tree\",\"origin\":\"Southeast Asia\",\"season\":\"autumn\",\"funFacts\":[{\"text\":\"When you slice me I make a perfect star shape!\",\"highlightWord\":\"star\",\"factType\":\"surprise\"},{\"text\":\"I am crunchy, juicy and taste sweet and sour!\",\"highlightWord\":\"crunchy\",\"factType\":\"surprise\"},{\"text\":\"You can eat my whole skin — no peeling needed!\",\"highlightWord\":\"skin\",\"factType\":\"surprise\"},{\"text\":\"I glow bright yellow when I am perfectly ripe!\",\"highlightWord\":\"yellow\",\"factType\":\"colour\"}],\"questions\":[{\"id\":\"starfruit-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour am I when ripe?\",\"options\":[{\"id\":\"starfruit-q1-a\",\"text\":null,\"colour\":\"#FFD700\",\"icon\":null},{\"id\":\"starfruit-q1-b\",\"text\":null,\"colour\":\"#FF4500\",\"icon\":null},{\"id\":\"starfruit-q1-c\",\"text\":null,\"colour\":\"#9400D3\",\"icon\":null},{\"id\":\"starfruit-q1-d\",\"text\":null,\"colour\":\"#A52A2A\",\"icon\":null}],\"correctOptionId\":\"starfruit-q1-a\",\"explanationCorrect\":\"Yes! I turn a beautiful bright yellow when ripe!\",\"explanationIncorrect\":\"Not quite! I turn golden yellow when ready to eat.\"},{\"id\":\"starfruit-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"starfruit-q2-a\",\"text\":\"Tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"starfruit-q2-b\",\"text\":\"Bush\",\"colour\":null,\"icon\":\"🌿\"},{\"id\":\"starfruit-q2-c\",\"text\":\"Vine\",\"colour\":null,\"icon\":\"🌱\"},{\"id\":\"starfruit-q2-d\",\"text\":\"Ground\",\"colour\":null,\"icon\":\"🌍\"}],\"correctOptionId\":\"starfruit-q2-a\",\"explanationCorrect\":\"Yes! I grow on small trees in warm tropical places!\",\"explanationIncorrect\":\"Nope! I grow on small trees in tropical countries.\"},{\"id\":\"starfruit-q3\",\"type\":\"true-false\",\"questionText\":\"I look like a star when cut. True or false?\",\"options\":[{\"id\":\"starfruit-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"starfruit-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"starfruit-q3-a\",\"explanationCorrect\":\"True! Every slice is a perfect five-pointed star!\",\"explanationIncorrect\":\"Actually true! Every slice is shaped like a star!\"},{\"id\":\"starfruit-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one does NOT belong with the others?\",\"options\":[{\"id\":\"starfruit-q4-a\",\"text\":\"Starfruit\",\"colour\":null,\"icon\":null},{\"id\":\"starfruit-q4-b\",\"text\":\"Lychee\",\"colour\":null,\"icon\":null},{\"id\":\"starfruit-q4-c\",\"text\":\"Guava\",\"colour\":null,\"icon\":null},{\"id\":\"starfruit-q4-d\",\"text\":\"Cauliflower\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"starfruit-q4-d\",\"explanationCorrect\":\"Correct! Cauliflower is a vegetable — the others are tropical fruits!\",\"explanationIncorrect\":\"Cauliflower is the odd one out — it's a vegetable!\"}],\"surpriseFact\":\"Every slice of starfruit is a perfect five-pointed star shape!\",\"difficulty\":\"medium\"},{\"id\":\"lemon\",\"name\":\"Lemon\",\"image\":\"/images/catalogue/lemon.webp\",\"category\":\"fruit\",\"subcategory\":\"citrus\",\"colours\":[\"yellow\"],\"growsOn\":\"tree\",\"origin\":\"Asia\",\"season\":\"all-year\",\"funFacts\":[{\"text\":\"I am bright yellow and very sour!\",\"highlightWord\":\"sour\",\"factType\":\"colour\"},{\"text\":\"I grow on trees in warm, sunny places!\",\"highlightWord\":\"sunny\",\"factType\":\"growth\"},{\"text\":\"I am packed with vitamin C to keep you healthy!\",\"highlightWord\":\"vitamin\",\"factType\":\"nutrition\"},{\"text\":\"I originally came from Asia thousands of years ago!\",\"highlightWord\":\"Asia\",\"factType\":\"origin\"}],\"questions\":[{\"id\":\"lemon-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour am I?\",\"options\":[{\"id\":\"lemon-q1-a\",\"text\":null,\"colour\":\"#FFD700\",\"icon\":null},{\"id\":\"lemon-q1-b\",\"text\":null,\"colour\":\"#E63946\",\"icon\":null},{\"id\":\"lemon-q1-c\",\"text\":null,\"colour\":\"#4CAF50\",\"icon\":null}],\"correctOptionId\":\"lemon-q1-a\",\"explanationCorrect\":\"Yes! I am bright yellow!\",\"explanationIncorrect\":\"Nearly! I am actually yellow!\"},{\"id\":\"lemon-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"lemon-q2-a\",\"text\":\"On a tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"lemon-q2-b\",\"text\":\"On a bush\",\"colour\":null,\"icon\":\"🌿\"},{\"id\":\"lemon-q2-c\",\"text\":\"Underground\",\"colour\":null,\"icon\":\"🕳️\"}],\"correctOptionId\":\"lemon-q2-a\",\"explanationCorrect\":\"Yes! I grow on a tree!\",\"explanationIncorrect\":\"No, I actually grow on a tree!\"},{\"id\":\"lemon-q3\",\"type\":\"true-false\",\"questionText\":\"Lemons taste sweet\",\"options\":[{\"id\":\"lemon-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"lemon-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"lemon-q3-b\",\"explanationCorrect\":\"Correct! Lemons are sour, not sweet!\",\"explanationIncorrect\":\"Actually, lemons are sour, not sweet!\"},{\"id\":\"lemon-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one is NOT a citrus fruit?\",\"options\":[{\"id\":\"lemon-q4-a\",\"text\":\"Orange\",\"colour\":null,\"icon\":null},{\"id\":\"lemon-q4-b\",\"text\":\"Lime\",\"colour\":null,\"icon\":null},{\"id\":\"lemon-q4-c\",\"text\":\"Strawberry\",\"colour\":null,\"icon\":null},{\"id\":\"lemon-q4-d\",\"text\":\"Grapefruit\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"lemon-q4-c\",\"explanationCorrect\":\"Yes! Strawberry is not a citrus fruit!\",\"explanationIncorrect\":\"Hmm, Strawberry is the odd one out!\"}],\"surpriseFact\":\"I can be used to make invisible ink!\",\"difficulty\":\"easy\"},{\"id\":\"lime\",\"name\":\"Lime\",\"image\":\"/images/catalogue/lime.webp\",\"category\":\"fruit\",\"subcategory\":\"citrus\",\"colours\":[\"green\"],\"growsOn\":\"tree\",\"origin\":\"Southeast Asia\",\"season\":\"all-year\",\"funFacts\":[{\"text\":\"I am small, round, and bright green!\",\"highlightWord\":\"green\",\"factType\":\"colour\"},{\"text\":\"I grow on trees in tropical climates!\",\"highlightWord\":\"tropical\",\"factType\":\"growth\"},{\"text\":\"I am related to lemons and oranges — we are citrus family!\",\"highlightWord\":\"citrus\",\"factType\":\"family\"},{\"text\":\"Sailors used me to prevent scurvy on long voyages!\",\"highlightWord\":\"scurvy\",\"factType\":\"surprise\"}],\"questions\":[{\"id\":\"lime-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour am I?\",\"options\":[{\"id\":\"lime-q1-a\",\"text\":null,\"colour\":\"#FFD700\",\"icon\":null},{\"id\":\"lime-q1-b\",\"text\":null,\"colour\":\"#4CAF50\",\"icon\":null},{\"id\":\"lime-q1-c\",\"text\":null,\"colour\":\"#FF6B35\",\"icon\":null}],\"correctOptionId\":\"lime-q1-b\",\"explanationCorrect\":\"Yes! I am green!\",\"explanationIncorrect\":\"Nearly! I am actually green!\"},{\"id\":\"lime-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"lime-q2-a\",\"text\":\"On a vine\",\"colour\":null,\"icon\":\"🌱\"},{\"id\":\"lime-q2-b\",\"text\":\"On a tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"lime-q2-c\",\"text\":\"Underground\",\"colour\":null,\"icon\":\"🕳️\"}],\"correctOptionId\":\"lime-q2-b\",\"explanationCorrect\":\"Yes! I grow on a tree!\",\"explanationIncorrect\":\"No, I actually grow on a tree!\"},{\"id\":\"lime-q3\",\"type\":\"true-false\",\"questionText\":\"Limes are a type of citrus fruit\",\"options\":[{\"id\":\"lime-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"lime-q3-b\",\"te