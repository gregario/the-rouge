\":\"sweeter\",\"factType\":\"colour\"},{\"text\":\"I grow underground from a trailing vine plant!\",\"highlightWord\":\"trailing\",\"factType\":\"growth\"},{\"text\":\"I am not actually related to regular potatoes at all!\",\"highlightWord\":\"related\",\"factType\":\"family\"},{\"text\":\"I am packed with beta-carotene and vitamin A!\",\"highlightWord\":\"beta-carotene\",\"factType\":\"nutrition\"}],\"questions\":[{\"id\":\"sweet-potato-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour am I inside?\",\"options\":[{\"id\":\"sweet-potato-q1-a\",\"text\":null,\"colour\":\"#FF8C00\",\"icon\":null},{\"id\":\"sweet-potato-q1-b\",\"text\":null,\"colour\":\"#4169E1\",\"icon\":null},{\"id\":\"sweet-potato-q1-c\",\"text\":null,\"colour\":\"#1a1a2e\",\"icon\":null}],\"correctOptionId\":\"sweet-potato-q1-a\",\"explanationCorrect\":\"Yes! I am orange inside!\",\"explanationIncorrect\":\"Nearly! I am orange inside!\"},{\"id\":\"sweet-potato-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"sweet-potato-q2-a\",\"text\":\"On a tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"sweet-potato-q2-b\",\"text\":\"On a bush\",\"colour\":null,\"icon\":\"🌿\"},{\"id\":\"sweet-potato-q2-c\",\"text\":\"Underground\",\"colour\":null,\"icon\":\"🕳️\"}],\"correctOptionId\":\"sweet-potato-q2-c\",\"explanationCorrect\":\"Yes! I grow underground!\",\"explanationIncorrect\":\"No, I actually grow underground!\"},{\"id\":\"sweet-potato-q3\",\"type\":\"true-false\",\"questionText\":\"Sweet potatoes and regular potatoes are closely related\",\"options\":[{\"id\":\"sweet-potato-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"sweet-potato-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"sweet-potato-q3-b\",\"explanationCorrect\":\"Correct! We are from completely different plant families!\",\"explanationIncorrect\":\"Actually, sweet potatoes are not closely related to regular potatoes!\"},{\"id\":\"sweet-potato-q4\",\"type\":\"odd-one-out\",\"questionText\":\"Which one does NOT grow underground?\",\"options\":[{\"id\":\"sweet-potato-q4-a\",\"text\":\"Sweet Potato\",\"colour\":null,\"icon\":null},{\"id\":\"sweet-potato-q4-b\",\"text\":\"Carrot\",\"colour\":null,\"icon\":null},{\"id\":\"sweet-potato-q4-c\",\"text\":\"Pumpkin\",\"colour\":null,\"icon\":null},{\"id\":\"sweet-potato-q4-d\",\"text\":\"Parsnip\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"sweet-potato-q4-c\",\"explanationCorrect\":\"Yes! Pumpkin grows on a vine on the ground!\",\"explanationIncorrect\":\"Hmm, Pumpkin is the odd one out — it grows on the ground!\"}],\"surpriseFact\":\"Sweet potatoes were carried into space by astronauts as an important food source!\",\"difficulty\":\"medium\"},{\"id\":\"turnip\",\"name\":\"Turnip\",\"image\":\"/images/catalogue/turnip.webp\",\"category\":\"vegetable\",\"subcategory\":\"root\",\"colours\":[\"white\",\"purple\"],\"growsOn\":\"underground\",\"origin\":\"Europe\",\"season\":\"winter\",\"funFacts\":[{\"text\":\"I am white and purple with a peppery taste!\",\"highlightWord\":\"peppery\",\"factType\":\"colour\"},{\"text\":\"I grow underground in cool autumn and winter weather!\",\"highlightWord\":\"cool\",\"factType\":\"growth\"},{\"text\":\"I am related to cabbage, broccoli, and kale!\",\"highlightWord\":\"cabbage\",\"factType\":\"family\"},{\"text\":\"I am low in calories and high in vitamin C!\",\"highlightWord\":\"calories\",\"factType\":\"nutrition\"}],\"questions\":[{\"id\":\"turnip-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour is my top?\",\"options\":[{\"id\":\"turnip-q1-a\",\"text\":null,\"colour\":\"#FF8C00\",\"icon\":null},{\"id\":\"turnip-q1-b\",\"text\":null,\"colour\":\"#6A0DAD\",\"icon\":null},{\"id\":\"turnip-q1-c\",\"text\":null,\"colour\":\"#4169E1\",\"icon\":null}],\"correctOptionId\":\"turnip-q1-b\",\"explanationCorrect\":\"Yes! My top is purple!\",\"explanationIncorrect\":\"Nearly! My top is purple and my bottom is white!