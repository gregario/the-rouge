\"season\":\"summer\",\"funFacts\":[{\"text\":\"I start red, then turn deep purple-black when ripe!\",\"highlightWord\":\"ripe\",\"factType\":\"colour\"},{\"text\":\"I grow on thorny canes called brambles!\",\"highlightWord\":\"brambles\",\"factType\":\"growth\"},{\"text\":\"I am related to raspberries and roses!\",\"highlightWord\":\"raspberries\",\"factType\":\"family\"},{\"text\":\"I am packed with vitamin C and antioxidants!\",\"highlightWord\":\"antioxidants\",\"factType\":\"nutrition\"}],\"questions\":[{\"id\":\"blackberry-q1\",\"type\":\"colour-match\",\"questionText\":\"What colour am I when ripe?\",\"options\":[{\"id\":\"blackberry-q1-a\",\"text\":null,\"colour\":\"#E63946\",\"icon\":null},{\"id\":\"blackberry-q1-b\",\"text\":null,\"colour\":\"#1a1a2e\",\"icon\":null},{\"id\":\"blackberry-q1-c\",\"text\":null,\"colour\":\"#FFD700\",\"icon\":null}],\"correctOptionId\":\"blackberry-q1-b\",\"explanationCorrect\":\"Yes! I am dark purple-black!\",\"explanationIncorrect\":\"Nearly! I am dark purple-black when ripe!\"},{\"id\":\"blackberry-q2\",\"type\":\"where-grow\",\"questionText\":\"Where do I grow?\",\"options\":[{\"id\":\"blackberry-q2-a\",\"text\":\"On a tree\",\"colour\":null,\"icon\":\"🌳\"},{\"id\":\"blackberry-q2-b\",\"text\":\"Underground\",\"colour\":null,\"icon\":\"🕳️\"},{\"id\":\"blackberry-q2-c\",\"text\":\"On a bush\",\"colour\":null,\"icon\":\"🌿\"}],\"correctOptionId\":\"blackberry-q2-c\",\"explanationCorrect\":\"Yes! I grow on a thorny bush!\",\"explanationIncorrect\":\"No, I actually grow on thorny bramble bushes!\"},{\"id\":\"blackberry-q3\",\"type\":\"true-false\",\"questionText\":\"Blackberries are green when unripe\",\"options\":[{\"id\":\"blackberry-q3-a\",\"text\":\"True\",\"colour\":null,\"icon\":null},{\"id\":\"blackberry-q3-b\",\"text\":\"False\",\"colour\":null,\"icon\":null}],\"correctOptionId\":\"blackberry-q3-b\",\"explanationCorrect\":\"Correct! I am red when unripe, not green!\",\"explanationIncorrect\":\"Actually, I am red when u