ies!\\\"},{\\\"id\\\":\\\"lentils-q2\\\",\\\"type\\\":\\\"where-grow\\\",\\\"questionText\\\":\\\"Where do I grow?\\\",\\\"options\\\":[{\\\"id\\\":\\\"lentils-q2-a\\\",\\\"text\\\":\\\"On a tree\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🌳\\\"},{\\\"id\\\":\\\"lentils-q2-b\\\",\\\"text\\\":\\\"On the ground\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🌾\\\"},{\\\"id\\\":\\\"lentils-q2-c\\\",\\\"text\\\":\\\"Underground\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🕳️\\\"}],\\\"correctOptionId\\\":\\\"lentils-q2-b\\\",\\\"explanationCorrect\\\":\\\"Yes! I grow on low bushy plants close to the ground!\\\",\\\"explanationIncorrect\\\":\\\"No, I grow on low bushy plants close to the ground!\\\"},{\\\"id\\\":\\\"lentils-q3\\\",\\\"type\\\":\\\"true-false\\\",\\\"questionText\\\":\\\"Lentils are a good source of protein\\\",\\\"options\\\":[{\\\"id\\\":\\\"lentils-q3-a\\\",\\\"text\\\":\\\"True\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"lentils-q3-b\\\",\\\"text\\\":\\\"False\\\",\\\"colour\\\":null,\\\"icon\\\":null}],\\\"correctOptionId\\\":\\\"lentils-q3-a\\\",\\\"explanationCorrect\\\":\\\"Correct! I am one of the best plant sources of protein!\\\",\\\"explanationIncorrect\\\":\\\"Actually, I am one of the best plant sources of protein!\\\"},{\\\"id\\\":\\\"lentils-q4\\\",\\\"type\\\":\\\"odd-one-out\\\",\\\"questionText\\\":\\\"Which one is NOT a legume?\\\",\\\"options\\\":[{\\\"id\\\":\\\"lentils-q4-a\\\",\\\"text\\\":\\\"Lentils\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"lentils-q4-b\\\",\\\"text\\\":\\\"Chickpeas\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"lentils-q4-c\\\",\\\"text\\\":\\\"Potato\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"lentils-q4-d\\\",\\\"text\\\":\\\"Peas\\\",\\\"colour\\\":null,\\\"icon\\\":null}],\\\"correctOptionId\\\":\\\"lentils-q4-c\\\",\\\"explanationCorrect\\\":\\\"Yes! Potato is a root vegetable, not a legume!\\\",\\\"explanationIncorrect\\\":\\\"Hmm, Potato is the odd one out — it is a root vegetable!\\\"}],\\\"surpriseFact\\\":\\\"Lentils were found in Egyptian tombs — they were buried with pharaohs as food for the afterlife!\\\",\\\"difficulty\\\":\\\"medium\\\"},{\\\"id\\\":\\\"onion\\\",\\\"name\\\":\\\"Onion\\\",\\\"image\\\":\\\"/images/catalogue/onion.webp\\\",\\\"category\\\":\\\"vegetable\\\",\\\"subcategory\\\":\\\"allium\\\",\\\"colours\\\":[\\\"brown\\\",\\\"white\\\",\\\"red\\\",\\\"purple\\\"],\\\"growsOn\\\":\\\"underground\\\",\\\"origin\\\":\\\"Central Asia\\\",\\\"season\\\":\\\"all-year\\\",\\\"funFacts\\\":[{\\\"text\\\":\\\"I can make you cry when you cut me — sorry!\\\",\\\"highlightWord\\\":\\\"cry\\\",\\\"factType\\\":\\\"surprise\\\"},{\\\"text\\\":\\\"I grow underground as a round layered bulb!\\\",\\\"highlightWord\\\":\\\"bulb\\\",\\\"factType\\\":\\\"growth\\\"},{\\\"text\\\":\\\"People have eaten me for over 5,000 years!\\\",\\\"highlightWord\\\":\\\"5,000\\\",\\\"factType\\\":\\\"origin\\\"},{\\\"text\\\":\\\"I can be white, red, brown or purple!\\\",\\\"highlightWord\\\":\\\"purple\\\",\\\"factType\\\":\\\"colour\\\"}],\\\"questions\\\":[{\\\"id\\\":\\\"onion-q1\\\",\\\"type\\\":\\\"colour-match\\\",\\\"questionText\\\":\\\"What colour is my skin most often?\\\",\\\"options\\\":[{\\\"id\\\":\\\"onion-q1-a\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#8B4513\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"onion-q1-b\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#00FF00\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"onion-q1-c\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#0000FF\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"onion-q1-d\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#FF69B4\\\",\\\"icon\\\":null}],\\\"correctOptionId\\\":\\\"onion-q1-a\\\",\\\"explanationCorrect\\\":\\\"Yes! Onion skins are often brown or papery!\\\",\\\"explanationIncorrect\\\":\\\"Onion skins are usually brown, white or red!\\\"},{\\\"id\\\":\\\"onion-q2\\\",\\\"type\\\":\\\"where-grow\\\",\\\"questionText\\\":\\\"Where do I grow?\\\",\\\"options\\\":[{\\\"id\\\":\\\"onion-q2-a\\\",\\\"text\\\":\\\"Underground\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🕳️\\\"},{\\\"id\\\":\\\"onion-q2-b\\\",\\\"text\\\":\\\"On a tree\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🌳\\\"},{\\\"id\\\":\\\"onion-q2-c\\\",\\\"text\\\":\\\"On a vine\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🌱\\\"},{\\\"id\\\":\\\"onion-q2-d\\\",\\\"text\\\":\\\"On a bush\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🌿\\\"}],\\\"correctOptionId\\\":\\\"onion-q2-a\\\",\\\"explanationCorrect\\\":\\\"Right! I grow underground as a bulb!\\\",\\\"explanationIncorrect\\\":\\\"I actually grow underground as a bulb!\\\"},{\\\"id\\\":\\\"onion-q3\\\",\\\"type\\\":\\\"true-false\\\",\\\"questionText\\\":\\\"Cutting me can make your eyes water. True or false?\\\",\\\"options\\\":[{\\\"id\\\":\\\"onion-q3-a\\\",\\\"text\\\":\\\"True\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"onion-q3-b\\\",\\\"text\\\":\\\"False\\\",\\\"colour\\\":null,\\\"icon\\\":null}],\\\"correctOptionId\\\":\\\"onion-q3-a\\\",\\\"explanationCorrect\\\":\\\"Yes! I release a gas that makes eyes water!\\\",\\\"explanationIncorrect\\\":\\\"Actually, cutting onions does make eyes water!\\\"},{\\\"id\\\":\\\"onion-q4\\\",\\\"type\\\":\\\"odd-one-out\\\",\\\"questionText\\\":\\\"Which one does NOT grow underground?\\\",\\\"options\\\":[{\\\"id\\\":\\\"onion-q4-a\\\",\\\"text\\\":\\\"Onion\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"onion-q4-b\\\",\\\"text\\\":\\\"Garlic\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"onion-q4-c\\\",\\\"text\\\":\\\"Carrot\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"onion-q4-d\\\",\\\"text\\\":\\\"Broccoli\\\",\\\"colour\\\":null,\\\"icon\\\":null}],\\\"correctOptionId\\\":\\\"onion-q4-d\\\",\\\"explanationCorrect\\\":\\\"Right! Broccoli grows above ground!\\\",\\\"explanationIncorrect\\\":\\\"Broccoli is the odd one — it grows above ground!\\\"}],\\\"surpriseFact\\\":\\\"Onions were so valuable in the Middle Ages that people used them to pay rent!\\\",\\\"difficulty\\\":\\\"easy\\\"},{\\\"id\\\":\\\"garlic\\\",\\\"name\\\":\\\"Garlic\\\",\\\"image\\\":\\\"/images/catalogue/garlic.webp\\\",\\\"category\\\":\\\"vegetable\\\",\\\"subcategory\\\":\\\"allium\\\",\\\"colours\\\":[\\\"white\\\",\\\"cream\\\",\\\"purple\\\"],\\\"growsOn\\\":\\\"underground\\\",\\\"origin\\\":\\\"Central Asia\\\",\\\"season\\\":\\\"all-year\\\",\\\"funFacts\\\":[{\\\"text\\\":\\\"I am made up of many little cloves inside!\\\",\\\"highlightWord\\\":\\\"cloves\\\",\\\"factType\\\":\\\"growth\\\"},{\\\"text\\\":\\\"I have been used as medicine for thousands of years!\\\",\\\"highlightWord\\\":\\\"medicine\\\",\\\"factType\\\":\\\"surprise\\\"},{\\\"text\\\":\\\"My strong smell comes from a chemical called allicin!\\\",\\\"highlightWord\\\":\\\"allicin\\\",\\\"factType\\\":\\\"nutrition\\\"},{\\\"text\\\":\\\"I originally grew wild in Central Asia!\\\",\\\"highlightWord\\\":\\\"Asia\\\",\\\"factType\\\":\\\"origin\\\"}],\\\"questions\\\":[{\\\"id\\\":\\\"garlic-q1\\\",\\\"type\\\":\\\"colour-match\\\",\\\"questionText\\\":\\\"What colour am I on the outside?\\\",\\\"options\\\":[{\\\"id\\\":\\\"garlic-q1-a\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#F5F5DC\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"garlic-q1-b\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#FF0000\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"garlic-q1-c\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#32CD32\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"garlic-q1-d\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#FFA500\\\",\\\"icon\\\":null}],\\\"correctOptionId\\\":\\\"garlic-q1-a\\\",\\\"explanationCorrect\\\":\\\"Yes! Garlic is creamy white on the outside!\\\",\\\"explanationIncorrect\\\":\\\"Garlic is usually white or cream coloured!\\\"},{\\\"id\\\":\\\"garlic-q2\\\",\\\"type\\\":\\\"where-grow\\\",\\\"questionText\\\":\\\"Where do I grow?\\\",\\\"options\\\":[{\\\"id\\\":\\\"garlic-q2-a\\\",\\\"text\\\":\\\"Underground\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🕳️\\\"},{\\\"id\\\":\\\"garlic-q2-b\\\