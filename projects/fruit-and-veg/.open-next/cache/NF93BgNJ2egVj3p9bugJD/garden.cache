ame\\\":\\\"Leek\\\",\\\"image\\\":\\\"/images/catalogue/leek.webp\\\",\\\"category\\\":\\\"vegetable\\\",\\\"subcategory\\\":\\\"allium\\\",\\\"colours\\\":[\\\"white\\\",\\\"green\\\"],\\\"growsOn\\\":\\\"ground\\\",\\\"origin\\\":\\\"Mediterranean\\\",\\\"season\\\":\\\"winter\\\",\\\"funFacts\\\":[{\\\"text\\\":\\\"I am the national symbol of Wales — go dragons!\\\",\\\"highlightWord\\\":\\\"Wales\\\",\\\"factType\\\":\\\"origin\\\"},{\\\"text\\\":\\\"I look like a very big spring onion!\\\",\\\"highlightWord\\\":\\\"spring\\\",\\\"factType\\\":\\\"family\\\"},{\\\"text\\\":\\\"I have a milder, sweeter taste than an onion!\\\",\\\"highlightWord\\\":\\\"sweeter\\\",\\\"factType\\\":\\\"surprise\\\"},{\\\"text\\\":\\\"My long green leaves fade to white at my base!\\\",\\\"highlightWord\\\":\\\"white\\\",\\\"factType\\\":\\\"colour\\\"}],\\\"questions\\\":[{\\\"id\\\":\\\"leek-q1\\\",\\\"type\\\":\\\"colour-match\\\",\\\"questionText\\\":\\\"What two colours am I?\\\",\\\"options\\\":[{\\\"id\\\":\\\"leek-q1-a\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#228B22\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"leek-q1-b\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#FF0000\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"leek-q1-c\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#FFA500\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"leek-q1-d\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#800080\\\",\\\"icon\\\":null}],\\\"correctOptionId\\\":\\\"leek-q1-a\\\",\\\"explanationCorrect\\\":\\\"Yes! I am green on top and white at the bottom!\\\",\\\"explanationIncorrect\\\":\\\"I am green at the top and white at my base!\\\"},{\\\"id\\\":\\\"leek-q2\\\",\\\"type\\\":\\\"where-grow\\\",\\\"questionText\\\":\\\"Where do I grow?\\\",\\\"options\\\":[{\\\"id\\\":\\\"leek-q2-a\\\",\\\"text\\\":\\\"On the ground\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🌾\\\"},{\\\"id\\\":\\\"leek-q2-b\\\",\\\"text\\\":\\\"Underground\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🕳️\\\"},{\\\"id\\\":\\\"leek-q2-c\\\",\\\"text\\\":\\\"On a tree\\\