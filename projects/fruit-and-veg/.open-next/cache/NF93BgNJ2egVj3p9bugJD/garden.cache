ur\\\":null,\\\"icon\\\":\\\"🌳\\\"},{\\\"id\\\":\\\"spring-onion-q2-d\\\",\\\"text\\\":\\\"On a bush\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🌿\\\"}],\\\"correctOptionId\\\":\\\"spring-onion-q2-a\\\",\\\"explanationCorrect\\\":\\\"Right! I grow upright in the soil!\\\",\\\"explanationIncorrect\\\":\\\"I actually grow upright in the ground!\\\"},{\\\"id\\\":\\\"spring-onion-q3\\\",\\\"type\\\":\\\"true-false\\\",\\\"questionText\\\":\\\"I am just a young onion picked early. True or false?\\\",\\\"options\\\":[{\\\"id\\\":\\\"spring-onion-q3-a\\\",\\\"text\\\":\\\"True\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"spring-onion-q3-b\\\",\\\"text\\\":\\\"False\\\",\\\"colour\\\":null,\\\"icon\\\":null}],\\\"correctOptionId\\\":\\\"spring-onion-q3-a\\\",\\\"explanationCorrect\\\":\\\"Yes! Spring onions are onions picked before they mature!\\\",\\\"explanationIncorrect\\\":\\\"Actually, spring onions really are young onions harvested early!\\\"},{\\\"id\\\":\\\"spring-onion-q4\\\",\\\"type\\\":\\\"odd-one-out\\\",\\\"questionText\\\":\\\"Which one does NOT belong in the onion family?\\\",\\\"options\\\":[{\\\"id\\\":\\\"spring-onion-q4-a\\\",\\\"text\\\":\\\"Spring Onion\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"spring-onion-q4-b\\\",\\\"text\\\":\\\"Garlic\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"spring-onion-q4-c\\\",\\\"text\\\":\\\"Shallot\\\",\\\"colour\\\":null,\\\"icon\\\":null},{\\\"id\\\":\\\"spring-onion-q4-d\\\",\\\"text\\\":\\\"Courgette\\\",\\\"colour\\\":null,\\\"icon\\\":null}],\\\"correctOptionId\\\":\\\"spring-onion-q4-d\\\",\\\"explanationCorrect\\\":\\\"Right! Courgette is a gourd, not in the onion family!\\\",\\\"explanationIncorrect\\\":\\\"Courgette is the odd one — it is a gourd, not an allium!\\\"}],\\\"surpriseFact\\\":\\\"Spring onions can regrow from their white roots if you put them in a glass of water!\\\",\\\"difficulty\\\":\\\"medium\\\"},{\\\"id\\\":\\\"courgette\\\",\\\"name\\\":\\\"Courgette\\\",\\\"image\\\":\\\"/images/catalogue/courgette.webp\\\",\\\"category\\\":\\\"vegetable\\\",\\\"subcategory\\\":\\\"gourd\\\",\\\"colours\\\":[\\\"green\\\",\\\"yellow\\\"],\\\"growsOn\\\":\\\"vine\\\",\\\"origin\\\":\\\"Mexico\\\",\\\"season\\\":\\\"summer\\\",\\\"funFacts\\\":[{\\\"text\\\":\\\"I am actually a fruit, but people cook me as a veg!\\\",\\\"highlightWord\\\":\\\"fruit\\\",\\\"factType\\\":\\\"surprise\\\"},{\\\"text\\\":\\\"I grow very fast — I can double in size overnight!\\\",\\\"highlightWord\\\":\\\"fast\\\",\\\"factType\\\":\\\"growth\\\"},{\\\"text\\\":\\\"In America they call me a zucchini!\\\",\\\"highlightWord\\\":\\\"zucchini\\\",\\\"factType\\\":\\\"origin\\\"},{\\\"text\\\":\\\"I am usually dark green but can also be yellow!\\\",\\\"highlightWord\\\":\\\"yellow\\\",\\\"factType\\\":\\\"colour\\\"}],\\\"questions\\\":[{\\\"id\\\":\\\"courgette-q1\\\",\\\"type\\\":\\\"colour-match\\\",\\\"questionText\\\":\\\"What colour am I usually?\\\",\\\"options\\\":[{\\\"id\\\":\\\"courgette-q1-a\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#228B22\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"courgette-q1-b\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#FF0000\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"courgette-q1-c\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#800080\\\",\\\"icon\\\":null},{\\\"id\\\":\\\"courgette-q1-d\\\",\\\"text\\\":null,\\\"colour\\\":\\\"#FF69B4\\\",\\\"icon\\\":null}],\\\"correctOptionId\\\":\\\"courgette-q1-a\\\",\\\"explanationCorrect\\\":\\\"Yes! Courgettes are usually dark green!\\\",\\\"explanationIncorrect\\\":\\\"Courgettes are usually dark green or sometimes yellow!\\\"},{\\\"id\\\":\\\"courgette-q2\\\",\\\"type\\\":\\\"where-grow\\\",\\\"questionText\\\":\\\"Where do I grow?\\\",\\\"options\\\":[{\\\"id\\\":\\\"courgette-q2-a\\\",\\\"text\\\":\\\"On a vine\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🌱\\\"},{\\\"id\\\":\\\"courgette-q2-b\\\",\\\"text\\\":\\\"On a tree\\\",\\\"colour\\\":null,\\\"icon\\\":\\\"🌳\\\"},{\\\"id\\\":\\\"courgette-